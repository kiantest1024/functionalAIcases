# 复制此文件为 .env 并填入真实值（或在系统中设置同名环境变量）

# ---------- MySQL（Web 应用与迁移脚本依赖）----------
#
# 【在 Windows 本机开发】若 MYSQL_HOST 使用 *.svc.cluster.local，系统无法解析该域名（getaddrinfo failed），
# 因为该地址只在 Kubernetes 集群 Pod 网络内有效。请任选其一：
#   A) 端口转发后再连本机（示例，命名空间/服务名按集群实际修改）：
#      kubectl port-forward -n mid svc/mysql-dev-primary 30200:3306
#      然后下面改为：MYSQL_HOST=127.0.0.1  MYSQL_PORT=30200
#   B) 把应用部署进同一集群，在 Pod 里用集群内域名。
#
# 集群内直连示例（仅 Pod 内可用）：
# MYSQL_HOST=mysql-dev-primary.mid.svc.cluster.local
# MYSQL_PORT=30200
# MYSQL_USER=testdpr
# MYSQL_PASSWORD=your_password_here
#
MYSQL_HOST=192.168.110.41
MYSQL_PORT=3306
MYSQL_USER=root
# 密码不要包一层引号；若写了引号，程序会自动去掉外层引号。
MYSQL_PASSWORD=Qwer1234..
MYSQL_DATABASE=test_case_generator
#
# 若 MySQL 跑在 Docker 里、应用在宿主机，错误日志里可能出现 root@172.17.0.1：
# 那是「MySQL 看到的客户端地址」，不是 MYSQL_HOST 配错。请给该来源授权，例如：
#   CREATE USER 'root'@'172.17.%' IDENTIFIED BY '密码'; GRANT ALL ON *.* TO 'root'@'172.17.%'; FLUSH PRIVILEGES;
# 也可尝试 MYSQL_HOST=127.0.0.1 并确保存在 'root'@'127.0.0.1'。

# ---------- AI（可选，部分部署通过 Web 界面配置）----------
# AI服务提供商 (openai, anthropic, google_gemini, etc.)
AI_PROVIDER=openai

# API密钥 (请替换为您的真实API密钥)
AI_API_KEY=your_api_key_here

# API基础URL (可选)
AI_BASE_URL=https://api.openai.com/v1

# 模型名称 (可选)
AI_MODEL=gpt-3.5-turbo

# 最大令牌数
AI_MAX_TOKENS=4000

# 温度参数
AI_TEMPERATURE=0.7

# 超时时间(秒)
AI_TIMEOUT=30
